sequenceDiagram
    autonumber
    participant T as Timer (5 min)
    participant M as BillingMeter
    participant R as TelemetryReader
    participant DB as Postgres

    loop every worker_billing_interval_seconds
        T->>M: tick()
        M->>R: snapshot()
        alt gateway offline (None)
            R-->>M: None
            M-->>M: skip sample (no fabricated data)
        else snapshot with clean_bytes per dp_id
            R-->>M: services[].clean_bytes, active.version
            M-->>M: delta = clean_bytes - prev[dp_id]
            M-->>M: reset? (delta<0 or version changed) -> use post-reset value
            M->>DB: upsert BillingSample(service_id, sample_ts, clean_bps)  [idempotent]
        end
        M->>DB: refresh open BillingUsage: p95 -> billed=max(committed,p95), overage
        alt period_end <= now  OR  service_id IS NULL (deleted)
            M->>DB: finalize -> status=final (immutable), finalized_at
        end
        M->>DB: prune BillingSample for finalized periods past retention
    end

    note over M,DB: p95_clean_gbps = nearest-rank(clean_bps) x 8 / 1e9<br/>billed_gbps = max(committed_clean_gbps, p95_clean_gbps)
