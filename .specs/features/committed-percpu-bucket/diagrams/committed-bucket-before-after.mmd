flowchart LR
    subgraph before ["BEFORE — committed = global bucket + bpf_spin_lock"]
        direction LR
        rssA["RSS spreads one hot VIP<br/>across N cores"]
        cpuA0["core 0<br/>fair_committed_admit()"]
        cpuA1["core 1"]
        cpuAn["core N-1"]
        lockA["svc_committed_state<br/>HASH 1024 → fair_committed_bucket (24 B)<br/>bpf_spin_lock + tokens + last_ns<br/><b>one cache line per service</b>"]
        rssA --> cpuA0 --> lockA
        rssA --> cpuA1 --> lockA
        rssA --> cpuAn --> lockA
    end

    subgraph after ["AFTER — committed = per-CPU bucket, lock-free"]
        direction LR
        rssB["RSS spreads one hot VIP<br/>across N cores"]
        cpuB0["core 0"]
        cpuB1["core 1"]
        cpuBn["core N-1"]
        pcB0["slot cpu0<br/>rl_bucket (32 B)"]
        pcB1["slot cpu1"]
        pcBn["slot cpuN-1"]
        rssB --> cpuB0 --> pcB0
        rssB --> cpuB1 --> pcB1
        rssB --> cpuBn --> pcBn
    end

    before -.->|"C1: PERCPU_HASH + rl_burst(rate, ncpus)<br/>each core gets committed_bps / ncpus"| after

    classDef hot fill:#f59e0b,stroke:#d97706,color:#ffffff
