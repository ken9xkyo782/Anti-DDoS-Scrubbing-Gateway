%% Diagram: Bypass & maintenance mode — component architecture (AD-032)
%%{init: {'theme': 'base', 'themeVariables': {
  'primaryColor': '#eef2ff', 'primaryTextColor': '#1e293b',
  'primaryBorderColor': '#4f46e5', 'lineColor': '#94a3b8',
  'secondaryColor': '#ecfdf5', 'tertiaryColor': '#fff7ed',
  'background': '#ffffff', 'mainBkg': '#f8fafc',
  'nodeBorder': '#cbd5e1', 'clusterBkg': '#f1f5f9',
  'clusterBorder': '#e2e8f0', 'titleColor': '#1e293b',
  'edgeLabelBackground': '#ffffff', 'textColor': '#334155'
}}}%%
graph TD
    admin["System admin"]
    dash["Dashboard SPA banner<br/>(P2, M5 shell)"]

    subgraph CP["Control-plane API"]
        pb["POST /node/bypass"]
        pm["POST /node/maintenance"]
        gh["GET /node/health"]
        svc["services/node_control.py<br/>set_bypass / set_maintenance"]
        audit["record_event → AuditEvent<br/>(dangerous-action)"]
        row[("node_control row<br/>desired state<br/>singleton")]
    end

    subgraph WK["Worker"]
        rec["NodeControlReconciler lane<br/>(separate task, tick 1s)"]
        gate["apply-dispatch gate<br/>_maintenance_active → hold job queued"]
        proc["process_job / reconcile_once"]
    end

    subgraph DP["Data-plane (XDP)"]
        setb["dpstat set-bypass 0|1"]
        nc[("node_control map<br/>1-slot array")]
        hot["hot path: parse → bypass? →<br/>redirect_out_bypass | service_lookup_redirect"]
        bcnt[("bypass_counter<br/>per-CPU array")]
        out["IN → OUT (verbatim)"]
    end

    reader["TelemetryReader.snapshot()<br/>+ bypass block"]
    snap["dpstat snapshot --json"]

    admin --> pb --> svc
    admin --> pm --> svc
    svc --> row
    svc --> audit
    audit -. consumed by .-> alerting["M6 Alerting<br/>(delivery)"]

    rec -->|read desired| row
    rec -->|drift → exec| setb --> nc
    rec -->|maintenance-clear edge| proc
    gate --> proc
    proc -->|reads| row

    nc -->|per-packet read| hot
    hot -->|bypass on| bcnt
    hot --> out

    admin --> gh --> reader
    dash -->|poll 2s| gh
    reader --> snap
    snap --> nc
    snap --> bcnt
    gh -->|desired ⊕ effective| dash

    classDef new fill:#eef2ff,stroke:#4f46e5,color:#1e293b;
    classDef reuse fill:#ecfdf5,stroke:#10b981,color:#1e293b;
    class pb,pm,gh,svc,row,rec,gate,setb,nc,bcnt,reader new;
    class audit,proc,hot,out,snap reuse;
