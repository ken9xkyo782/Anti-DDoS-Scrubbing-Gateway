flowchart TD
    dropPath(["Any drop path<br/>parse fail-fast · service_miss/disabled · future M3"]) -->|"record_drop(&amp;meta, reason)"| clampCheck{"reason &lt; DROP_REASON_COUNT?"}
    clampCheck -- "no — fail-closed" --> clampFix["reason = DR_MAP_ERROR"]
    clampFix --> counterInc
    clampCheck -- yes --> counterInc["counter_map[reason]++<br/>per-CPU · exact · unconditional"]
    counterInc --> tokenCheck{"token bucket has budget?<br/>per-CPU · refill rate/s · cap burst"}
    tokenCheck -- no --> suppressed["sample_stats[SUPPRESSED]++"]
    tokenCheck -- yes --> reserve{"bpf_ringbuf_reserve(32 B)"}
    reserve -- "NULL — buffer full" --> lost["sample_stats[LOST]++"]
    reserve -- ok --> submit["fill drop_event from pkt_meta<br/>bpf_ringbuf_submit"]
    submit --> emitted["sample_stats[EMITTED]++"]
    suppressed --> verdict(["return XDP_DROP"])
    lost --> verdict
    emitted --> verdict

    classDef exact fill:#10b981,stroke:#059669,color:#ffffff
    classDef bestEffort fill:#f59e0b,stroke:#d97706,color:#ffffff
    class counterInc exact
    class suppressed,lost,emitted,submit bestEffort
